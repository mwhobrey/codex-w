# Arc B — copy to apps/web/.env.local

# --- Local Docker Postgres (npm run stack:up) ---
DATABASE_URL=postgresql://codex:codex@localhost:5433/codex
# DATABASE_DRIVER=postgres   # optional; auto-detected for localhost

# --- Or Neon cloud (production / optional remote dev) ---
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
# DATABASE_DRIVER=neon

# Better Auth — generate: openssl rand -base64 32
BETTER_AUTH_SECRET=local-dev-change-me-use-openssl-rand
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Self-hosted Yjs relay (npm run dev:sync)
NEXT_PUBLIC_SYNC_HOST=127.0.0.1:1999
NEXT_PUBLIC_SYNC_CONNECT=true
# Legacy aliases (still supported):
# NEXT_PUBLIC_PARTYKIT_HOST=127.0.0.1:1999
# NEXT_PUBLIC_PARTYKIT_CONNECT=true

# S3-compatible storage — point at your existing local MinIO (default :9000).
# Create a bucket once, e.g.: mc mb local/codex-assets
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=your-minio-access-key
S3_SECRET_KEY=your-minio-secret-key
S3_BUCKET=codex-assets
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:9000/codex-assets
