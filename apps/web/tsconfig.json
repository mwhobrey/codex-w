{
  "extends": "@codex/config/typescript/nextjs",
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["@serwist/next/typings"],
    "lib": ["dom", "dom.iterable", "ES2022", "webworker"]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules", "public/sw.js"]
}
